# Backend environment — copy to .env and fill in real values.
# .env is gitignored; never commit real secrets.
PORT=3000

# PostgreSQL — option A: hosted (Neon). If set, this takes precedence and SSL is enabled.
# Get it from the Neon console: Project > Connect > connection string.
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DBNAME?sslmode=require

# PostgreSQL — option B: local Docker (matches docker-compose.yml)
DB_HOST=localhost
DB_PORT=5433
DB_USER=ats
DB_PASSWORD=change-me
DB_NAME=ats_expenses

# Auth — generate a secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# CORS: comma-separated allowed origins (frontend dev server)
CORS_ORIGIN=http://localhost:4200
